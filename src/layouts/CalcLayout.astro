---
import '../styles/tokens.css';
import { softwareApplicationSchema, faqSchema, breadcrumbSchema } from '../lib/schema';
import type { CalcSpec } from '../lib/types';
import { getAllCalcs } from '../lib/calcs';

interface Props {
  spec: CalcSpec;
}
const { spec } = Astro.props;
const allCalcs = getAllCalcs();

const schemaApp  = softwareApplicationSchema(spec);
const schemaFaq  = faqSchema(spec.faq ?? []);
const schemaBc   = breadcrumbSchema(spec.slug, spec.title);
const canonicalUrl = `https://reicalcs.com/${spec.slug}`;
const ogImage = `/og/${spec.slug}.svg`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{spec.metaTitle}</title>
  <meta name="description" content={spec.metaDescription} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- OG / Twitter -->
  <meta property="og:title"       content={spec.metaTitle} />
  <meta property="og:description" content={spec.metaDescription} />
  <meta property="og:image"       content={`https://reicalcs.com${ogImage}`} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:type"        content="website" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content={spec.metaTitle} />
  <meta name="twitter:description" content={spec.metaDescription} />
  <meta name="twitter:image"      content={`https://reicalcs.com${ogImage}`} />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBc)} />

  <!-- Plausible -->
  <script defer data-domain="reicalcs.com" src="https://plausible.io/js/script.js"></script>

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body class="min-h-screen bg-white">

  <!-- Nav -->
  <header class="border-b border-slate-200 bg-white sticky top-0 z-10">
    <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
      <a href="/" class="font-bold text-navy-900 text-lg tracking-tight">REI Calcs</a>
      <details class="relative group">
        <summary class="cursor-pointer list-none flex items-center gap-1.5 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors marker:content-none">
          All Calcs
          <svg class="h-4 w-4 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="absolute right-0 top-full mt-2 w-64 rounded-xl border border-slate-200 bg-white shadow-lg py-2 z-20">
          {allCalcs.map((c) => (
            <a href={`/${c.slug}`} class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">{c.title}</a>
          ))}
        </div>
      </details>
    </nav>
  </header>

  <main class="mx-auto max-w-3xl px-4 py-10">
    <!-- Hero -->
    <div class="mb-8">
      <h1 class="mb-2">{spec.h1}</h1>
      <p class="text-slate-500 text-base">{spec.tagline || spec.metaDescription}</p>
    </div>

    <!-- Calculator widget -->
    <slot name="calculator" />

    <!-- Affiliate CTA -->
    <div class="mt-5">
      <slot name="affiliate" />
    </div>

    <!-- Embed snippet -->
    <details class="mt-6 group">
      <summary class="cursor-pointer text-sm text-slate-500 hover:text-slate-700 marker:content-none flex items-center gap-1.5">
        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
        </svg>
        Embed this calculator
      </summary>
      <div class="mt-3 rounded-lg bg-slate-50 border border-slate-200 p-4">
        <pre class="text-xs text-slate-600 overflow-x-auto whitespace-pre-wrap"><code>{`<iframe src="https://reicalcs.com/embed/${spec.slug}" width="100%" height="420" frameborder="0" title="${spec.title}" loading="lazy"></iframe>`}</code></pre>
        <button
          onclick={`navigator.clipboard.writeText('<iframe src="https://reicalcs.com/embed/${spec.slug}" width="100%" height="420" frameborder="0" title="${spec.title}" loading="lazy"></iframe>').then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='Copy embed code'},2000)})`}
          class="mt-2 text-xs font-medium text-blue-600 hover:underline"
        >
          Copy embed code
        </button>
      </div>
    </details>

    <!-- Explainer content -->
    <article class="mt-12 prose prose-slate max-w-none prose-headings:font-semibold prose-a:text-blue-600">
      <slot name="content" />
    </article>

    <!-- FAQ -->
    <slot name="faq" />

    <!-- Related -->
    <slot name="related" />
  </main>

  <footer class="border-t border-slate-200 mt-16 py-8 text-center text-xs text-slate-400">
    <div class="mx-auto max-w-5xl px-4 flex flex-wrap items-center justify-center gap-4">
      <span>&copy; {new Date().getFullYear()} REI Calcs</span>
      <a href="/how-we-make-money" class="hover:text-slate-600">How we make money</a>
      <a href="/privacy" class="hover:text-slate-600">Privacy</a>
    </div>
  </footer>

</body>
</html>

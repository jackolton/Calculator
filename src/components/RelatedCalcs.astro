---
import { getCalcMeta } from '../lib/calcs';

interface Props {
  slugs: string[];
}
const { slugs } = Astro.props;
const calcs = slugs.map(getCalcMeta).filter(Boolean);
---

{calcs.length > 0 && (
  <section class="mt-10">
    <h2 class="mb-4">Related calculators</h2>
    <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {calcs.map((calc) => (
        <li>
          <a
            href={`/${calc!.slug}`}
            class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 hover:border-blue-300 hover:text-blue-700 transition-colors"
          >
            <svg class="h-4 w-4 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z" />
            </svg>
            {calc!.title}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

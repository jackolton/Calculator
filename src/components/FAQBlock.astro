---
interface Props {
  items: { question: string; answer: string }[];
}
const { items } = Astro.props;
---

{items.length > 0 && (
  <section style="margin-top: 48px;">
    <h2 style="margin-bottom: 16px;">Frequently asked questions</h2>
    <dl style="display: flex; flex-direction: column; gap: 8px;">
      {items.map((item) => (
        <details class="group" style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden;">
          <summary style="cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px 18px; font-size: 13px; font-weight: 600; color: var(--color-text); list-style: none; transition: background 100ms; font-family: var(--font-body);" class="hover:bg-google-hover marker:content-none">
            {item.question}
            <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180" style="color: var(--color-text-muted);" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div style="padding: 12px 18px 16px; font-size: 13px; color: var(--color-text-muted); line-height: 1.7; border-top: 1px solid var(--color-divider); font-family: var(--font-body);">
            {item.answer}
          </div>
        </details>
      ))}
    </dl>
  </section>
)}

---
interface Props {
  partner: string;
  headline: string;
  cta: string;
  url: string;
}
const { headline, cta, url } = Astro.props;
---

<div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 16px 20px; display: flex; flex-direction: column; gap: 12px;" class="sm:flex-row sm:items-center">
  <p style="flex: 1; font-size: 14px; color: var(--color-text); margin: 0; line-height: 1.5;">{headline}</p>
  <a
    href={url}
    rel="sponsored nofollow"
    target="_blank"
    class="btn-primary"
    style="flex-shrink: 0; text-align: center;"
  >
    {cta}
  </a>
</div>

---
interface Props {
  partner: string;
  headline: string;
  cta: string;
  url: string;
}
const { headline, cta, url } = Astro.props;
---

<div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 16px 20px; display: flex; flex-wrap: wrap; align-items: center; gap: 14px;">
  <p style="flex: 1; min-width: 180px; font-size: 13px; font-weight: 500; color: var(--color-text); margin: 0; line-height: 1.5; font-family: var(--font-body);">{headline}</p>
  <a
    href={url}
    rel="sponsored nofollow"
    target="_blank"
    class="btn-primary"
    style="white-space: nowrap;"
  >
    {cta}
  </a>
</div>

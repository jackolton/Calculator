---
import '../styles/tokens.css';
import { getAllCalcs } from '../lib/calcs';
const calcs = getAllCalcs();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>REI Calcs — Free Real Estate Investor Calculators</title>
  <meta name="description" content="Free calculators for real estate investors. Cap rate, DSCR, cash-on-cash, BRRRR, and more. No signup, no ads above the fold." />
  <link rel="canonical" href="https://reicalcs.com/" />
  <script defer data-domain="reicalcs.com" src="https://plausible.io/js/script.js"></script>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body class="min-h-screen bg-white">

  <header class="border-b border-slate-200 bg-white">
    <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
      <a href="/" class="font-bold text-navy-900 text-lg tracking-tight">REI Calcs</a>
    </nav>
  </header>

  <main class="mx-auto max-w-5xl px-4 py-16">
    <div class="max-w-2xl mb-12">
      <h1 class="text-4xl font-bold mb-4">Real estate investor calculators</h1>
      <p class="text-slate-500 text-lg">Free, fast, no signup. Crunch the numbers on any deal in seconds.</p>
    </div>

    <div id="calculators" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {calcs.map((calc) => (
        <a
          href={`/${calc.slug}`}
          class="card p-5 hover:shadow-md transition-shadow group"
        >
          <div class="flex items-start gap-3">
            <div class="rounded-lg bg-blue-50 p-2 shrink-0">
              <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z" />
              </svg>
            </div>
            <div>
              <h2 class="text-base font-semibold text-slate-900 group-hover:text-blue-700 transition-colors">{calc.title}</h2>
              <p class="text-sm text-slate-500 mt-0.5 line-clamp-2">{calc.metaDescription}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-slate-200 mt-16 py-8 text-center text-xs text-slate-400">
    <div class="mx-auto max-w-5xl px-4 flex flex-wrap items-center justify-center gap-4">
      <span>&copy; {new Date().getFullYear()} REI Calcs</span>
      <a href="/how-we-make-money" class="hover:text-slate-600">How we make money</a>
      <a href="/privacy" class="hover:text-slate-600">Privacy</a>
    </div>
  </footer>

</body>
</html>

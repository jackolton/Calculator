---
import '../styles/tokens.css';
import { getAllCalcs } from '../lib/calcs';
const calcs = getAllCalcs();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>REI Calcs — Free Real Estate Investor Calculators</title>
  <meta name="description" content="Free calculators for real estate investors. Cap rate, DSCR, cash-on-cash, BRRRR, and more. No signup, no ads above the fold." />
  <link rel="canonical" href="https://reicalcs.com/" />
  <script defer data-domain="reicalcs.com" src="https://plausible.io/js/script.js"></script>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style>
    .calc-card {
      opacity: 0;
      animation: fadeUp 0.4s cubic-bezier(0.22,1,0.36,1) both;
    }
  </style>
</head>
<body style="min-height: 100vh;">

  <!-- App bar -->
  <header style="background: var(--color-surface); border-bottom: 1px solid var(--color-divider);">
    <nav style="max-width: 1024px; margin: 0 auto; padding: 0 20px; height: 64px; display: flex; align-items: center;">
      <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
        <span style="width: 28px; height: 28px; background: var(--color-primary); border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;" aria-hidden="true">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
            <rect x="2" y="2" width="4.5" height="4.5" rx="1" fill="white" opacity="0.9"/>
            <rect x="8.5" y="2" width="4.5" height="4.5" rx="1" fill="white" opacity="0.7"/>
            <rect x="2" y="8.5" width="4.5" height="4.5" rx="1" fill="white" opacity="0.7"/>
            <rect x="8.5" y="8.5" width="4.5" height="4.5" rx="1" fill="white" opacity="0.9"/>
          </svg>
        </span>
        <span style="font-family: var(--font-display); font-size: 17px; font-weight: 700; color: var(--color-text); letter-spacing: -0.03em;">
          REI Calcs
        </span>
      </a>
    </nav>
  </header>

  <main style="max-width: 1024px; margin: 0 auto; padding: 56px 20px 96px;">

    <!-- Hero -->
    <div class="animate-hero" style="max-width: 560px; margin-bottom: 48px;">
      <h1 style="font-size: 2.25rem; margin-bottom: 14px;">
        Real estate investor<br/>calculators
      </h1>
      <p style="font-size: 15px; color: var(--color-text-muted); line-height: 1.65; margin: 0;">
        Free, fast, no signup. Crunch the numbers on any deal in seconds.
      </p>
    </div>

    <!-- Calc grid -->
    <div style="display: grid; gap: 12px; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));">
      {calcs.map((calc, i) => (
        <a
          href={`/${calc.slug}`}
          class="card card-hover calc-card"
          style={`padding: 20px; text-decoration: none; display: flex; align-items: flex-start; gap: 14px; animation-delay: ${i * 45}ms;`}
        >
          <div style="width: 40px; height: 40px; background: var(--color-primary-lt); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 150ms;">
            <svg style="width: 20px; height: 20px; color: var(--color-primary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z" />
            </svg>
          </div>
          <div style="min-width: 0;">
            <p style="font-family: var(--font-display); font-size: 14px; font-weight: 600; color: var(--color-text); margin: 0 0 5px; line-height: 1.35; letter-spacing: -0.01em;">{calc.title}</p>
            <p style="font-size: 12px; color: var(--color-text-muted); margin: 0; line-height: 1.55; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">{calc.metaDescription}</p>
          </div>
        </a>
      ))}
    </div>
  </main>

  <footer style="border-top: 1px solid var(--color-divider); padding: 28px 20px; text-align: center;">
    <div style="max-width: 1024px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 20px; font-size: 12px; color: var(--color-text-muted);">
      <span style="font-weight: 700; font-family: var(--font-display); letter-spacing: -0.02em; color: var(--color-text);">REI Calcs</span>
      <a href="/how-we-make-money" style="color: var(--color-text-muted); text-decoration: none;">How we make money</a>
      <a href="/privacy" style="color: var(--color-text-muted); text-decoration: none;">Privacy</a>
    </div>
  </footer>

</body>
</html>

---
import '../../styles/tokens.css';
import { getAllCalcs, getCalcBySlug } from '../../lib/calcs';
import Calculator from '../../components/Calculator.astro';

export async function getStaticPaths() {
  const calcs = getAllCalcs();
  return calcs.map((spec) => ({ params: { slug: spec.slug } }));
}

const { slug } = Astro.params;
const spec = getCalcBySlug(slug!)!;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{spec.title}</title>
  <meta name="robots" content="noindex" />
</head>
<body style="background: var(--color-bg); padding: 16px; margin: 0;">
  <p style="font-size: 13px; font-weight: 500; color: var(--color-text); margin: 0 0 12px;">{spec.h1}</p>
  <Calculator spec={spec} />
  <p style="margin-top: 12px; font-size: 11px; color: var(--color-text-muted); text-align: center;">
    Powered by <a href={`https://reicalcs.com/${spec.slug}`} target="_blank" style="color: var(--color-primary); text-decoration: none;">REI Calcs</a>
  </p>
</body>
</html>
